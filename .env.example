# =============================================================================
# PulseIQ — Environment Variables
# Copy this file to .env and fill in your values. Never commit .env.
# =============================================================================

# -----------------------------------------------------------------------------
# Data source API keys
# -----------------------------------------------------------------------------

# Bureau of Labor Statistics API key
# Register at: https://www.bls.gov/developers/
BLS_API_KEY=

# Federal Reserve Economic Data (FRED) API key
# Register at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# NewsAPI key — replaced Reddit as sentiment/news source
# Register at: https://newsapi.org
NEWS_API_KEY=

# US Census Bureau API key
# Register at: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# OpenWeatherMap API key — free tier covers PulseIQ's needs
# Register at: https://openweathermap.org/api
OPENWEATHER_API_KEY=

# Google Trends — no API key needed (uses pytrends, free)
# No key required

# -----------------------------------------------------------------------------
# LLM Provider — RAG explanation generation
# -----------------------------------------------------------------------------

# OpenRouter LLM for RAG explanations
OPENROUTER_API_KEY=your_key_here
LLM_PROVIDER=openrouter
LLM_MODEL=xiaomi/mimo-v2-flash
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_TEMPERATURE=0.1

# -----------------------------------------------------------------------------
# Embeddings — news article vectorisation for RAG
# -----------------------------------------------------------------------------

# Which embedding provider to use
# Values: local | nvidia
# local = BAAI/bge-large-en-v1.5 via sentence-transformers (free, no key)
# nvidia = nv-embedqa-e5-v5 via Nvidia NIM API (requires separate provider auth)
EMBEDDING_PROVIDER=local

# Embedding model name
# local:  BAAI/bge-large-en-v1.5  (512 token context, 1024 dims, free)
# nvidia: nvidia/nv-embedqa-e5-v5  (4096 dims, best quality)
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5

# -----------------------------------------------------------------------------
# Infrastructure
# -----------------------------------------------------------------------------

# Path to the DuckDB database file (relative to project root)
DUCKDB_PATH=data/processed/pulseiq.db

# Path to the ChromaDB persistent storage directory
CHROMADB_PATH=data/processed/chroma/

# MLflow tracking server URI
# Run locally with: mlflow ui --port 5000
MLFLOW_TRACKING_URI=http://localhost:5000

# Airflow home directory
AIRFLOW_HOME=./airflow

# -----------------------------------------------------------------------------
# Alerts
# -----------------------------------------------------------------------------

# ESS score threshold above which webhook alerts fire (0-100)
ALERT_THRESHOLD=75

# URL that receives POST requests when alert threshold is crossed
ALERT_WEBHOOK_URL=

# Shared secret used to sign outbound webhook payloads
ALERT_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------

# Runtime environment
# Values: development | production
ENVIRONMENT=development

# Python logging level
# Values: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
